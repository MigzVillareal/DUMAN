// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MeetingStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  userId    Int    @id @default(autoincrement())
  username  String @unique
  email     String @unique
  firstname String
  lastname  String
  password  String @map("password_hash")

  ownedGroups   Group[]
  setMeetings   Meeting[]
  groupMembers  GroupMember[]
  notifications Notification[]

  sentInvites GroupMember[] @relation("invitedBy")

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  calendars Calendar[]

  @@map("users")
}

model Group {
  groupId     Int     @id @default(autoincrement())
  name        String
  description String?

  members       GroupMember[]
  notifications Notification[]
  meetings      Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [userId])
  userId    Int?
  calendars Calendar[]

  @@unique([groupId, userId])
  @@map("groups")
}

model GroupMember {
  memberId  Int
  groupId   Int
  role      Role         @default(MEMBER)
  status    InviteStatus @default(PENDING)
  invitedBy Int
  joinedAt  DateTime?

  user     User  @relation(fields: [memberId], references: [userId], onDelete: Cascade)
  group    Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  invitier User  @relation("invitedBy", fields: [invitedBy], references: [userId])

  @@id([memberId, groupId])
  @@map("members")
}

model Meeting {
  meetingId      Int           @id @default(autoincrement())
  title          String
  description    String?
  status         MeetingStatus @default(UPCOMING)
  locationDetail String?

  schedule DateTime
  endsAt   DateTime?

  setterId        Int
  intendedGroupId Int

  setter        User           @relation(fields: [setterId], references: [userId])
  intendedGroup Group          @relation(fields: [intendedGroupId], references: [groupId])
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meetings")
}

model Notification {
  notificationId Int  @id @default(autoincrement())
  userId         Int
  groupId        Int
  meetingId      Int? // optional, not all notifications may be meeting-related

  subject String
  body    String             @db.Text
  status  NotificationStatus @default(PENDING)

  user    User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  group   Group    @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model Calendar {
  calendarId Int @id @default(autoincrement())
  groupId    Int
  userId     Int

  user  User  @relation(fields: [userId], references: [userId])
  group Group @relation(fields: [groupId], references: [groupId])

  @@map("calendars")
}
