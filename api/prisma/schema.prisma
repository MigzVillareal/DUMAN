// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum MeetingStatus {
  UPCOMING
  ONGOING
  FINISHED
}

model User {
  userId            Int       @id @default(autoIncrement())
  username          String
  email             @unique
  firstname         String
  lastname          String

  groups            Group[]   @relation
  meetings          Meeting[]
  notifications     Notification

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("users")
}

model Meeting {
  meetingId               Int     @id @default(autoIncrement())
  meetingNumber           Int
  title                   String
  description             String?
  category                String
  meetingStatus           MeetingStatus

  latitude                float
  longitude               float
  locationDescription     String

  schedule                DateTime

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  //actual foreign key column stored in the database
  setterId          Int
  intendedGroupId   Int
  
  //prisma relation mapping
  setter            User      @relation(fields: [setterId], references: [userId])
  intendedGroup     Group     @relation(fields: [intendedGroupId], references: [groupId])
  
  @@map("meetings")
}

model Group {
  groupId           Int       @id @default(autoIncrement())
  groupName         String
  groupDescription  String?
  groupColor        String

  groupCalendarId

  calendar          calendar

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("groups")
}

model Calendar {
  calendarId      @id @default(autoIncrement())

  @@map("calendars")
}

model Notification {
  notificationId      @id @default(autoIncrement())
  userId
  title

  @@map("notifications")
}